# Wyze credentials for the QLab → Wyze bridge.
# Copy this file to ".env" (which is git-ignored) and fill in your values.
# The bridge loads .env automatically at startup.

WYZE_EMAIL=you@example.com
WYZE_PASSWORD=your-wyze-password

# From https://developer-api-console.wyze.com/
WYZE_KEY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
WYZE_API_KEY=yourLongApiKeyString

# Only needed if your account uses an authenticator-app (TOTP) for 2FA.
# WYZE_TOTP_KEY=your-totp-secret
